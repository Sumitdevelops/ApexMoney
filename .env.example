# ============================================
# REQUIRED - MUST SET BEFORE DEPLOYMENT
# ============================================

# Database
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/apexmoney

# Session Security (generate random 32+ character string)
SESSION_SECRET=your_super_secret_session_key_min_32_characters_change_this_now

# Authentication - Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/auth/google/callback

# Email Service (Resend)
RESEND_API_KEY=re_your_actual_api_key_here

# ============================================
# OPTIONAL - ONLY IF USING AI SERVICES
# ============================================

# AI Services (optional)
GROK_API_KEY=your_grok_api_key_if_using_grok
GOOGLE_AI_API_KEY=your_google_ai_api_key_if_using_gemini

# ============================================
# ENVIRONMENT & PORT
# ============================================

# Environment (development, production, testing)
NODE_ENV=production

# Port (default 8000)
PORT=8000

# ============================================
# CORS & FRONTEND URLS
# ============================================

# Production frontend URL
FRONTEND_URL=https://apexmoney.netlify.app

# Local development (localhost:5173)
FRONTEND_URL_LOCAL=http://localhost:5173

# ============================================
# OPTIONAL - ERROR TRACKING & MONITORING
# ============================================

# Sentry (optional, for error tracking)
# Get from: https://sentry.io/
SENTRY_DSN=your_sentry_dsn_here
