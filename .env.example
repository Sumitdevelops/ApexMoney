# Database
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/apexmoney

# Session
SESSION_SECRET=your_super_secret_session_key_min_32_characters

# JWT (if using JWT auth)
JWT_SECRET=your_super_secret_jwt_key_min_32_characters

# Authentication - Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# Email Service
RESEND_API_KEY=your_resend_api_key

# AI Services
GROK_API_KEY=your_grok_api_key
GOOGLE_AI_API_KEY=your_google_ai_api_key

# Environment
NODE_ENV=production
PORT=8000

# Frontend URLs for CORS and OAuth redirects
FRONTEND_URL=https://apexmoney.netlify.app
FRONTEND_URL_LOCAL=http://localhost:5173

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_GENERAL_MAX=60

# Data Retention
DATA_RETENTION_DAYS=2555
